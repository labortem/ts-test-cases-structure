{
	"js/ts.preferences.importModuleSpecifier": "non-relative",
	"js/ts.tsserver.experimental.enableProjectDiagnostics": true,
	"material-icon-theme.files.associations": {
		"index.ts": "tsconfig"
	},
	"local-history.exclude": [
